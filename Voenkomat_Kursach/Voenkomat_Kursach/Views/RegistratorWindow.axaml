<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Voenkomat_Kursach.Views.RegistratorWindow"
        Title="RegistratorWindow">
    <TabControl>
            <TabItem Header="Посещения">
                <StackPanel>
                    <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto" Margin="10">
                        <TextBlock Text="дата | " Grid.Row="0" Grid.Column="0"/>
                        <TextBlock Text="09.05.2026" Grid.Row="0" Grid.Column="1"/>
                        <TextBlock Text="имя | " Grid.Row="1" Grid.Column="0"/>
                        <TextBlock Text="пес патрон" Grid.Row="1" Grid.Column="1"/>
                    </Grid>
                    <Button Content="Сохранить" Margin="10" HorizontalAlignment="Center" Width="100"/>
                </StackPanel>
            </TabItem>
    
            <TabItem Header="Личные дела">
                <TabControl>
                    <TabItem Header="найти">
                        <StackPanel Margin="10">
                            <TextBlock Text="Форма поиска"/>
                            <TextBox Watermark="Введите данные для поиска"/>
                            <Button Content="Найти" Margin="5"/>
                        </StackPanel>
                    </TabItem>
                    <TabItem Header="завести">
                        <StackPanel Margin="10">
                            <TextBlock Text="Форма создания"/>
                            <TextBox Watermark="ФИО"/>
                            <TextBox Watermark="Дата рождения"/>
                            <Button Content="Завести" Margin="5"/>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </TabItem>
    
            <TabItem Header="Повестки">
                <StackPanel Margin="10">
                    <TextBox Watermark="ФИО призывника" Margin="0,5"/>
                    <TextBox Watermark="Дата явки" Margin="0,5"/>
                    <TextBox Watermark="Причина" Margin="0,5"/>
                    <TextBox Watermark="Место явки" Margin="0,5"/>
                    <Button Content="Выдать" Margin="5" HorizontalAlignment="Center" Width="100"/>
                </StackPanel>
            </TabItem>
        </TabControl>
</Window>
