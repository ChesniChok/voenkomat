<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Voenkomat_Kursach.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Voenkomat_Kursach.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Voenkomat_Kursach">
        
        <!--старое
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                <Button Content="Войти как Врач" Width="250" Height="50" Click="OnDoctor"/>
                <Button Content="Войти как Регистрирующий" Width="250" Height="50" Click="OnRegistrator"/>
        </StackPanel>
        -->
        
        
        <!-- вход в аккаунт -->
        <Grid RowDefinitions="* Auto Auto Auto *">
                
                <TextBox Text="{Binding Login}" Grid.Row="1"/>
                <TextBox Text="{Binding Password}" Grid.Row="2"/>
                
                <Button Content="{Binding ButtonText}" Command="{Binding LogInCommand}" Grid.Row="3"/>
                
        </Grid>
        
        
</Window>
